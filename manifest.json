{
  "manifest_version": 3,
  "name": "TexVault",
  "short_name": "TexVault",
  "version": "1.0",
  "description": "Your LaTeX snippet vault. Browse 100+ built-in templates or save your own, organized into folders and ready to copy instantly.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png",
    "512": "icons/icon512.png"
  },

  "action": {
    "default_popup": "index.html",
    "default_title": "TexVault",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png",
      "512": "icons/icon512.png"
    }
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+T",
        "mac":     "Alt+T"
      },
      "description": "Open TexVault"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "clipboardWrite",
    "contextMenus"
  ]
}
